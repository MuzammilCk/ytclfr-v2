ENVIRONMENT=development
SERVICE_NAME=ytclfr
LOG_LEVEL=INFO
LOG_FORMAT=json
API_PORT=8000
METRICS_ENABLED=true
METRICS_NAMESPACE=ytclfr
WORKER_METRICS_PORT=9100
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Required core config
DATABASE_URL=postgresql+psycopg://ytclfr:ytclfr@localhost:5432/ytclfr
REDIS_URL=redis://redis:6379/0
OPENROUTER_API_KEY=replace_me
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
STORAGE_PATH=./storage
MAX_VIDEO_DURATION=3600

# Optional runtime config
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false

YT_DLP_BIN=yt-dlp
YT_DLP_COOKIES_FROM_BROWSER=brave
YT_DLP_COOKIE_FILE=
YT_DLP_RETRY_WITHOUT_COOKIES=true
YT_DLP_PLAYER_CLIENT=tv
YT_DLP_SLEEP_INTERVAL=2
YT_DLP_MAX_SLEEP_INTERVAL=5
YT_DLP_EXTRACTOR_ARGS=player_client=tv
YT_DLP_JS_RUNTIMES=node
FFMPEG_BIN=ffmpeg
FRAME_EXTRACTION_FPS=1
OCR_LANGUAGE=en
OCR_USE_GPU=false
OCR_BATCH_SIZE=8
OCR_MIN_CONFIDENCE=0.5

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_PARSE_MAX_RETRIES=3

SPOTIFY_AUTH_URL=https://accounts.spotify.com/api/token
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
SPOTIFY_TIMEOUT_SECONDS=30
SPOTIFY_USER_ID=
SPOTIFY_USER_ACCESS_TOKEN=

TMDB_WEB_BASE_URL=https://www.themoviedb.org
GOODREADS_WEB_BASE_URL=https://www.goodreads.com

CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
